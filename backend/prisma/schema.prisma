generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id           Int      @id @default(autoincrement())
  nome         String
  email        String   @unique
  senha        String
  cpf          String   @unique
  telefone     String
  tipoChavePix String
  chavePix     String
  role         String   @default("USER")
  ativo        Boolean  @default(true)
  palpites     Palpite[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Confronto {
  id              Int       @id @default(autoincrement())
  selecaoA        String
  selecaoB        String
  dataHora        DateTime
  local           String
  valorSugerido   Float
  golsTimeA       Int?
  golsTimeB       Int?
  status          String    @default("ABERTO")
  palpitesAbertos Boolean   @default(true)
  palpites        Palpite[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Palpite {
  id          Int      @id @default(autoincrement())
  usuarioId   Int
  confrontoId Int
  golsTimeA   Int
  golsTimeB   Int
  pontos      Int      @default(0)
  createdAt   DateTime @default(now())
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
  confronto   Confronto @relation(fields: [confrontoId], references: [id])
}
